{
  "paths": {
    "/api/users/signUp": {
      "post": {
        "tags": ["Users"],
        "summary": "Register a new user account",
        "description": "Creates a fresh database document for a user. The incoming fields must pass strict Mongoose validation schema checks (valid email layout, strong password rules, and defined user types).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserSignUpRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User account created and registered successfully.",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "_id": "65bcf123e4b0cc123456789a",
                    "name": "Jane Doe",
                    "email": "janedoe@example.com",
                    "type": "customer",
                    "createdAt": "2026-06-10T18:15:00.000Z",
                    "updatedAt": "2026-06-10T18:15:00.000Z"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Database or registration transaction exception thrown."
          }
        }
      }
    },
    "/api/users/signIn": {
      "post": {
        "tags": ["Users"],
        "summary": "Authenticate user credentials",
        "description": "Verifies account credentials using a secure hash matrix check. Returns a stateless JWT bearer authorization token valid for 1 hour upon success.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "janedoe@example.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "Password@123"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful. Plain textual token string returned directly.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI2NWJjZjEyM2U0Yj..."
                }
              }
            }
          },
          "400": {
            "description": "Incorrect credentials provided."
          },
          "500": {
            "description": "Database validation check failure."
          }
        }
      }
    },
    "/api/users/resetPassword": {
      "put": {
        "tags": ["Users"],
        "summary": "Reset user password credentials",
        "description": "Modifies the authenticated user's current credentials. The raw text payload passes straight to Mongoose where it is fully re-validated against password policy regex filters before being hashed via pre-save life cycle hooks.",
        "security": [
          {
            "JWT": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "newPassword": {
                    "type": "string",
                    "format": "password",
                    "description": "Must pass strong formatting checks (min 8 characters, 1 uppercase, 1 lowercase, 1 digit, 1 special character).",
                    "example": "NewSecurePassword@99"
                  }
                },
                "required": ["newPassword"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password is reset successfully.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Password is reset"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized: Missing, invalid, or expired authorization header credentials token."
          },
          "500": {
            "description": "User matching record missing or processing transaction dropped."
          }
        }
      }
    }
  },
  "schemas": {
    "UserSignUpRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "Jane Doe"
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "janedoe@example.com"
        },
        "password": {
          "type": "string",
          "format": "password",
          "description": "Requires min 8 chars, 1 uppercase, 1 lowercase, 1 digit, and 1 special character symbol.",
          "example": "Password@123"
        },
        "type": {
          "type": "string",
          "enum": ["customer", "seller"],
          "example": "customer"
        }
      },
      "required": ["name", "email", "password", "type"]
    }
  }
}